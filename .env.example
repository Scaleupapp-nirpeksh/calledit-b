# ============================================
# CalledIt Backend - Environment Variables
# Phase 1 Configuration
# ============================================
# IMPORTANT: Copy this file to .env and fill in real values
# NEVER commit .env to git. Only .env.example gets committed.

# App
APP_ENV=development                # development | staging | production
APP_SECRET_KEY=<generate-with-openssl-rand-hex-32>
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/calledit
MONGODB_DB=calledit

# Redis (local dev uses docker-compose Redis, production uses AWS ElastiCache)
REDIS_URL=redis://localhost:6379/0

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Cricket Data (CricAPI v2 — full version)
CRICAPI_KEY=<your-cricapi-key>
CRICAPI_BASE_URL=https://api.cricapi.com/v1

# Auth - Twilio (OTP)
TWILIO_ACCOUNT_SID=<your-twilio-sid>
TWILIO_AUTH_TOKEN=<your-twilio-auth-token>
TWILIO_PHONE_NUMBER=<your-twilio-phone>
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30

# AWS
AWS_ACCESS_KEY_ID=<your-aws-key>
AWS_SECRET_ACCESS_KEY=<your-aws-secret>
AWS_REGION=ap-south-1
S3_BUCKET=calledit-assets

# --- PHASE 2 (not needed yet) ---
# CDN_URL=https://cdn.calledit.in
# GOOGLE_CLIENT_ID=<google-oauth>
# FIREBASE_CREDENTIALS_PATH=/app/firebase-creds.json
# RAZORPAY_KEY_ID=<key>
# RAZORPAY_KEY_SECRET=<secret>
# RAZORPAY_WEBHOOK_SECRET=<webhook-secret>
# SENTRY_DSN=https://xxx@sentry.io/xxx
